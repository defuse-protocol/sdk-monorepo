{
	"name": "@defuse-protocol/internal-utils",
	"version": "0.35.2",
	"private": false,
	"type": "module",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/defuse-protocol/sdk-monorepo.git",
		"directory": "packages/internal-utils"
	},
	"bugs": {
		"url": "https://github.com/defuse-protocol/sdk-monorepo/issues"
	},
	"homepage": "https://github.com/defuse-protocol/sdk-monorepo/tree/main/packages/internal-utils#readme",
	"sideEffects": false,
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsdown",
		"dev": "tsdown --watch",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@defuse-protocol/contract-types": "workspace:*",
		"@lifeomic/attempt": "^3.0.0",
		"@noble/curves": "^1.4.0",
		"@noble/hashes": "^1.7.1",
		"@scure/base": "^1.0.0",
		"@thames/monads": "^0.7.0",
		"near-api-js": "^4.0.0 || ^5.0.0",
		"tweetnacl": "^1.0.0",
		"valibot": "^1.0.0",
		"viem": "^2.0.0"
	},
	"devDependencies": {
		"msw": "^2.11.3",
		"tsdown": "0.19.0",
		"typescript": "^5.4.2"
	}
}
